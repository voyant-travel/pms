{
  "name": "pms-admin",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "generate:voyant": "voyant build --artifacts-only && node scripts/generate-wrangler-config.mjs",
    "generate:voyant:self-host": "VOYANT_PRODUCT_JOB_SCHEDULE_AUTHORITY=cloudflare-cron pnpm run generate:voyant",
    "generate:voyant:managed": "VOYANT_PRODUCT_JOB_SCHEDULE_AUTHORITY=managed-http pnpm run generate:voyant",
    "predev": "pnpm run generate:voyant:self-host",
    "dev": "vite dev --port 3300",
    "prebuild": "pnpm run generate:voyant",
    "build": "vite build",
    "build:self-host": "VOYANT_PRODUCT_JOB_SCHEDULE_AUTHORITY=cloudflare-cron pnpm run build",
    "build:managed": "VOYANT_PRODUCT_JOB_SCHEDULE_AUTHORITY=managed-http pnpm run build",
    "preview": "pnpm run build:self-host && vite preview",
    "pretypecheck": "pnpm run generate:voyant:self-host",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=14336 tsc -p tsconfig.server.json && NODE_OPTIONS=--max-old-space-size=14336 tsc -p tsconfig.client.json",
    "pretest": "pnpm run generate:voyant:self-host",
    "test": "vitest run --passWithNoTests",
    "generate:openapi": "UPDATE_OPENAPI=1 vitest run src/api/openapi.test.ts",
    "deploy": "pnpm run deploy:self-host",
    "deploy:self-host": "pnpm run build:self-host && wrangler deploy --config .voyant/wrangler.self-host.generated.json",
    "deploy:managed": "pnpm run build:managed && wrangler deploy --config .voyant/wrangler.managed.generated.json",
    "check:startup": "pnpm run build:self-host && wrangler check startup --config .voyant/wrangler.self-host.generated.json",
    "measure:startup": "pnpm run build:self-host && node ../../scripts/measure-cloudflare-startup.mjs .",
    "db:generate": "drizzle-kit generate --config=drizzle.deployment-migrations.config.ts",
    "db:generate:deployment": "drizzle-kit generate --config=drizzle.deployment-migrations.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check --config=drizzle.deployment-migrations.config.ts",
    "db:studio": "drizzle-kit studio",
    "reindex": "tsx scripts/reindex.ts",
    "seed": "tsx scripts/seed-acme.ts",
    "seed:acme": "tsx scripts/seed-acme.ts",
    "sync:sources": "tsx scripts/sync-sources.ts",
    "notifications:mock": "node scripts/mock-notifications.mjs",
    "cf-typegen": "pnpm run generate:voyant:self-host && wrangler types --config .voyant/wrangler.self-host.generated.json --env-interface CloudflareBindings",
    "lint": "biome check src/"
  },
