{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "warn"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.voyant",
      "!**/.next",
      "!**/.wrangler",
      "!**/.vinxi",
      "!**/.output",
      "!**/.turbo",
      "!**/.claude",
      "!**/*.gen.ts",
      "!**/*.generated.ts",
      "!**/*.generated.tsx",
      "!**/migrations",
      "!apps/pms/openapi",
      "!apps/pms/src/components/ui",
      "!apps/pms/src/lib/async-utils.ts",
      "!apps/pms/src/styles.css"
    ]
  }
}
