{
  "name": "@voyant-travel/pms-front-desk",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/pms.git",
    "directory": "packages/front-desk"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "biome check src/",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@voyant-travel/accommodations": "^0.109.9",
    "@voyant-travel/bookings": "0.141.1",
    "@voyant-travel/db": "0.109.5",
    "@voyant-travel/framework": "^0.12.20",
    "@voyant-travel/hono": "0.121.3",
    "@voyant-travel/pms-housekeeping": "workspace:*",
    "@voyant-travel/pms-units": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
