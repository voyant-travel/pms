{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "composite": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": false,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*"]
}
