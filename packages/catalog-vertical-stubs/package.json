{
  "name": "@voyant-travel/pms-catalog-vertical-stubs",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    "./voyant": {
      "types": "./dist/voyant.d.ts",
      "import": "./dist/voyant.js",
      "default": "./dist/voyant.js"
    },
    "./runtime-contributor": {
      "types": "./dist/runtime-contributor.d.ts",
      "import": "./dist/runtime-contributor.js",
      "default": "./dist/runtime-contributor.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "^6.0.3"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createPmsCatalogVerticalStubRuntimePortContribution"
    }
  }
}
