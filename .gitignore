# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist

# Vendored prebuilt demo packages carried from the operator blueprint.
# These ship only a compiled `dist/` (no source), so their dist is the
# source of truth and must be tracked despite the global `dist` ignore.
!packages/plugin-catalog-demo/dist
!packages/plugin-catalog-demo/dist/**
!packages/realtime-react/dist
!packages/realtime-react/dist/**

# TanStack Start / Cloudflare Worker local build + secrets (app-level).
.dev.vars
.wrangler
.voyant
.output
.tanstack
.nitro


# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem
